# ═══════════════════════════════════════════════════════════════
# .gitignore - HR看板项目
# 防止敏感数据和临时文件上传到GitHub
# ═══════════════════════════════════════════════════════════════

# 真实HR数据（绝对不能上传！）
data_sample/
data/
*.xlsx
*.xls
*.csv

# Python虚拟环境
venv/
env/
.venv/
env/
ENV/

# Python缓存
__pycache__/
*.py[cod]
*$py.class
*.so
.Python

# 配置文件（可能包含密码）
.env
.secrets
*.secrets

# IDE配置
.vscode/
.idea/
*.swp
*.swo
*~

# Streamlit缓存
.streamlit/secrets.toml

# 日志文件
*.log
streamlit.log

# 临时文件
temp/
tmp/
*.tmp
*.bak
*.backup

# 生成的报告（可能包含真实数据）
*_report_*.md
*_package_*.zip
output/
exports/
